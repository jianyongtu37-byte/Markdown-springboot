REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ========== Elasticsearch 配置 ==========
# Elasticsearch 连接配置
ES_HOST=localhost
ES_PORT=9200
ES_USERNAME=elastic
ES_PASSWORD=27qdN79RiGZ8q3ZoT0mG

# ========== JWT 配置 ==========
# JWT 密钥和过期时间
JWT_SECRET=markdown-knowledge-base-secret-key-2025-spring-boot-4.0.5-jwt-token-secret
JWT_EXPIRATION=86400

# ========== DeepSeek AI 配置 ==========
# 从 https://platform.deepseek.com/ 获取 API Key
DEEPSEEK_API_KEY=sk-803fc935f7814956a33e98f04786e909
DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=30
DEEPSEEK_MAX_TOKENS=500

# ========== 应用配置 ==========
# 应用端口
SERVER_PORT=8080

# ========== 日志级别 ==========
# 日志级别：DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# ========== 邮件服务器配置 ==========
# QQ邮箱 SMTP 配置
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=2170736492@qq.com
MAIL_PASSWORD=jrprjfwqqaduebee
MAIL_PROTOCOL=smtp
MAIL_SMTP_AUTH=true
MAIL_STARTTLS_ENABLE=true
MAIL_STARTTLS_REQUIRED=true
MAIL_SSL_ENABLE=false
MAIL_CONNECTION_TIMEOUT=5000
MAIL_TIMEOUT=5000
MAIL_WRITETIMEOUT=5000

# ========== 应用配置 ==========
# 应用访问URL，用于生成邮件中的链接
APP_URL=http://localhost:8080

# ========== 开发模式配置 ==========
# 是否启用开发模式
SPRING_PROFILES_ACTIVE=dev

# ========== Elasticsearch 配置 ==========
# 是否启用 Elasticsearch 仓库（如果ES服务未运行，可设为false）
SPRING_DATA_ELASTICSEARCH_REPOSITORIES_ENABLED=true
